# vim: ft=dockerfile
# Start with the base image for PostgreSQL 17.4
FROM postgres:17.4

# Install PostgreSQL 15 binaries
RUN apt-get update && \
    apt-get install -y postgresql-15 && \
    rm -rf /var/lib/apt/lists/*

# Set environment variables for pg_upgrade
ENV PATH="${PATH}:/usr/lib/postgresql/15/bin"
